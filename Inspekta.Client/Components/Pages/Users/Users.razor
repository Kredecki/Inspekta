@page "/users"
@attribute [Authorize(Policy = "AdminPolicy")]

<div id="main-container">
	<div>
		<TableHeader
			SearchTerm="@SearchTerm"
			SearchTermChanged="OnSearchChangedAsync"
			RecordsPerPage="@RecordsPerPage"
			RecordsPerPageChanged="OnRecordsPerPageChangedAsync"
			AddClicked="AddUser" />
		<div class="table-scroll">
			<table>
				<thead>
					<tr>
						<th>
							Lp
							<span class="material-symbols-outlined"
								  @onclick="@(() => SortBy("LP"))">
								@GetSortIcon("LP")
							</span>
						</th>
						<th>
							Login
							<span class="material-symbols-outlined"
								  @onclick="@(() => SortBy("Login"))">
								@GetSortIcon("Login")
							</span>
						</th>
						<th>
							Rola
							<span class="material-symbols-outlined"
								  @onclick="@(() => SortBy("Role"))">
								@GetSortIcon("Role")
							</span>
						</th>
					</tr>
				</thead>
				<tbody>
					@for (int i = 0; i < Model.Items.Count; i++)
					{
						<tr @ondblclick="@(() => Details(Model.Items[i].Id))">
							<td>@GetRowNumber(i)</td>
							<td>@Model.Items[i].Login</td>
							<td>@Model.Items[i].Role</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
	<Pagger CurrentPage="@CurrentPage"
			Pages="@Pages"
			CurrentPageChanged="ChangePageAsync" />
</div>